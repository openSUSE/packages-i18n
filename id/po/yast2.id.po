msgstr "YaST - peninjauan snapshot sistem berkas"

#. leap/yast2-snapper/description
msgid "YaST module for accessing and managing file-system snapshots"
msgstr "Modul YaST untuk mengakses dan mengelola snapshot sistem berkas"

#. leap/yast2-sound/summary
msgid "YaST2 - Sound Configuration"
msgstr "YaST2 - Konfigurasi Suara"

