#. leap/yast2-security/summary
msgid "YaST2 - Security Configuration"
msgstr "YaST2 - Konfigurasi Keamanan"

#. leap/yast2-security/description
msgid "The YaST2 component for security settings configuration."
msgstr "Komponen YaST2 untuk konfigurasi pengaturan keamanan."

#. leap/yast2-services-manager/summary
msgid "YaST2 - Services Manager"
msgstr "YaST2 - Manajer Layanan"

#. leap/yast2-services-manager/description
msgid ""
"Provides user interface and libraries to configure systemd services and "
